<!-- Sidebar category tree (server-side rendered, zero JS dependency) -->
<style>
.sidebar-cat-tree { margin-top: 20px; font-size: 0.82rem; line-height: 1.5; }
.sidebar-cat-title { font-weight: 600; font-size: 0.9rem; margin-bottom: 10px; opacity: 0.8; }
.scat-group { margin-bottom: 8px; }
.scat-root { display: flex; justify-content: space-between; align-items: center; padding: 4px 0; cursor: pointer; font-weight: 600; font-size: 0.85rem; user-select: none; opacity: 0.85; transition: opacity 0.15s; }
.scat-root:hover { opacity: 1; }
.scat-arrow { font-size: 0.6rem; opacity: 0.4; transition: transform 0.2s; }
.scat-group.open > .scat-root .scat-arrow { transform: rotate(90deg); }
.scat-children { display: none; padding-left: 12px; }
.scat-group.open > .scat-children { display: block; }
.scat-sub { margin-bottom: 4px; }
.scat-sub-h { display: flex; justify-content: space-between; align-items: center; padding: 2px 0; cursor: pointer; opacity: 0.7; font-size: 0.8rem; user-select: none; transition: opacity 0.15s; }
.scat-sub-h:hover { opacity: 0.9; }
.scat-sub.open > .scat-sub-h .scat-arrow { transform: rotate(90deg); }
.scat-links { display: none; padding-left: 8px; }
.scat-sub.open > .scat-links { display: block; }
.scat-links--direct { display: block; padding-left: 12px; }
.scat-links a { display: block; padding: 2px 0; opacity: 0.6; font-size: 0.78rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; transition: opacity 0.15s; }
.scat-links a:hover { opacity: 1; text-decoration: underline; }
</style>

<div class="sidebar-cat-tree">
  <div class="sidebar-cat-title">📂 文章分类</div>
  {{ sidebar_cat_tree() | safe }}
</div>
