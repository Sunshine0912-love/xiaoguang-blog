<!-- Category tree for sidebar -->
<div class="sidebar-cat-tree" id="sidebarCatTree">
  <a class="sidebar-cat-title" href="/xiaoguang-blog/categories/">📂 文章分类</a>
</div>

<script>
(function() {
  var el = document.getElementById('sidebarCatTree');
  if (!el) return;

  var root = '/xiaoguang-blog/';
  var meta = document.querySelector('meta[property="og:url"]');
  if (meta) {
    try {
      var path = new URL(meta.content).pathname;
      var marker = '/xiaoguang-blog/';
      var index = path.indexOf(marker);
      root = index === -1 ? '/' : path.slice(0, index + marker.length);
    } catch(e) {}
  }

  fetch(root + 'categories-data.json')
    .then(function(r) { return r.json(); })
    .then(function(posts) {
      var tree = {};
      posts.forEach(function(post) {
        var rc = post.c[0], sc = post.c.length > 1 ? post.c[1] : null;
        if (!rc) return;
        if (!tree[rc]) tree[rc] = {};
        var k = sc || '_direct';
        if (!tree[rc][k]) tree[rc][k] = [];
        tree[rc][k].push(post);
      });

      var html = '';
      Object.keys(tree).sort().forEach(function(rc) {
        var scs = tree[rc];
        var total = 0;
        Object.keys(scs).forEach(function(k) { total += scs[k].length; });

        html += '<div class="scat-group">';
        html += '<button class="scat-root" type="button" aria-expanded="false">';
        html += '<span>' + rc + ' (' + total + ')</span><span class="scat-arrow">▶</span></button>';
        html += '<div class="scat-children">';

        Object.keys(scs).sort().forEach(function(sc) {
          var p = scs[sc];
          if (sc !== '_direct') {
            html += '<div class="scat-sub">';
            html += '<button class="scat-sub-h" type="button" aria-expanded="false">';
            html += '<span>' + sc + ' (' + p.length + ')</span><span class="scat-arrow">▶</span></button>';
            html += '<div class="scat-links">';
            p.forEach(function(post) {
              html += '<a href="' + post.u + '" title="' + post.t + '">' + post.t + '</a>';
            });
            html += '</div></div>';
          } else {
            html += '<div class="scat-links scat-links--direct">';
            p.forEach(function(post) {
              html += '<a href="' + post.u + '" title="' + post.t + '">' + post.t + '</a>';
            });
            html += '</div>';
          }
        });

        html += '</div></div>';
      });

      // Insert after the title
      var title = el.querySelector('.sidebar-cat-title');
      if (title) {
        var div = document.createElement('div');
        div.innerHTML = html;
        title.after(div);
        div.querySelectorAll('.scat-root, .scat-sub-h').forEach(function(button) {
          button.addEventListener('click', function(event) {
            event.preventDefault();
            var group = button.parentElement;
            var isOpen = group.classList.toggle('open');
            button.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
          });
        });
      }
    });
})();
</script>
