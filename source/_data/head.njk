{%- if page.mathjax or theme.math.every_page %}
  <link rel="stylesheet" href="{{ url_for('/lib/katex/katex.min.css') }}">
  <style>
    .post-body section,
    .post-body eqn,
    .post-body .katex-display {
      max-width: 100%;
      overflow-x: auto;
      overflow-y: hidden;
    }
    .post-body .katex-display {
      padding-bottom: 0.25rem;
    }
    .post-body .katex-display > .katex {
      max-width: 100%;
    }
    .post-body table {
      display: block;
      max-width: 100%;
      overflow-x: auto;
    }
  </style>
{%- endif %}

{%- if config.ai_assistant and config.ai_assistant.enabled %}
  <link rel="stylesheet" href="{{ url_for('/css/xiaoguang-teacher.css') }}">
  <script>
    window.XIAOGUANG_TEACHER_CONFIG = {
      apiUrl: "{{ config.ai_assistant.api_url | default('') }}",
      modelLabel: "{{ config.ai_assistant.model_label | default('DeepSeek V4 Pro') }}",
      siteRoot: "{{ config.root | default('/') }}"
    };
  </script>
  <script defer src="{{ url_for('/js/xiaoguang-teacher.js') }}"></script>
{%- endif %}
